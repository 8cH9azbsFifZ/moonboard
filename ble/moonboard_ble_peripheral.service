[Unit]
Description=Moonboard BLE Peripheral Service
Wants=bluetooth.service dbus.service hciuart.service mosquitto.service
After=bluetooth.service dbus.service hciuart.service mosquitto.service network-online.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
WorkingDirectory=/home/pi/moonboard/ble
# Ensure BLE adapter advertises as "Moonboard A" (matches what the iOS app scans for).
# Without this, the chip broadcasts the system hostname (e.g. "raspi-moonboard")
# and the Moonboard app fails to discover the device.
ExecStartPre=/usr/bin/btmgmt name "Moonboard A" "MBA"
ExecStart=/usr/bin/python3 /home/pi/moonboard/ble/moonboard_ble_peripheral.py --mqtt-host localhost
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=moonboard-ble

[Install]
WantedBy=multi-user.target
